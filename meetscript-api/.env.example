# ── MeetScript Environment Variables ──

# Application
ENV=development
SECRET_KEY=change-me-to-a-random-secret-key-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://meetscript:meetscript@postgres:5432/meetscript

# Redis
REDIS_URL=redis://redis:6379
REDIS_BROKER_DB=0
REDIS_RESULT_DB=1
REDIS_CACHE_DB=2

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage (minio / oss / s3)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=meetscript
MINIO_SECURE=false

# Aliyun OSS (optional, for production)
# OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=meetscript

# AI / DashScope
DASHSCOPE_API_KEY=your-dashscope-api-key

# Celery
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_DELAY=60
CELERY_TASK_RETRY_BACKOFF_MAX=600

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# Upload
MAX_UPLOAD_SIZE_MB=2048

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# File Processing
AUDIO_SEGMENT_DURATION=1800
AUDIO_TARGET_SAMPLE_RATE=16000
AUDIO_TARGET_CHANNELS=1
AUDIO_TARGET_FORMAT=wav
FFMPEG_TIMEOUT=300
